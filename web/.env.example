# Build-time vars for Vite — set before npm run build (Railway: project Variables)

VITE_SITE_URL=https://lilagent.xyz



# Empty when API and web share the same domain (recommended on Railway)

VITE_API_URL=



# Match server RPC_URL

VITE_RPC_URL=



# Match server REFERRER_ADDRESS

VITE_REFERRER_ADDRESS=



# Token images CDN

VITE_MEDIA_BASE_URL=https://api.alt.fun



# Optional — Telegram bot link on /bot page (username only, no @)

VITE_TELEGRAM_BOT_USERNAME=

