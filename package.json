{
  "name": "lila-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && npm run build --prefix web",
    "start:bot": "tsx src/index.ts bot",
    "start:bot:prod": "node dist/index.js bot",
    "start:server": "tsx src/index.ts server",
    "start:server:prod": "node dist/index.js server",
    "start:cli": "tsx src/index.ts cli",
    "dev:bot": "tsx watch src/index.ts bot",
    "dev:server": "tsx src/index.ts server",
    "dev:web": "npm run dev --prefix web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "better-sqlite3": "^11.9.1",
    "dotenv": "^16.5.0",
    "grammy": "^1.36.0",
    "hono": "^4.7.10",
    "viem": "^2.30.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
