# =============================================================================
# EXTERNAL AGENT ONLY — OpenClaw / Cursor MCP (`npm run mcp` → mcp/lila-server.mjs)
# Do NOT put these on the LILA HTTP API server (Railway, etc.). They never run there.
# Copy values into OpenClaw: mcp.servers.<name>.env — or merge with your local .env for MCP.
# =============================================================================

# API origin (no trailing slash)
LILA_BASE_URL=https://lilagent.xyz

# Payer wallet (pick one path):
# 1) Inline secret (S...)
# LILA_PAYER_SECRET=

# 2) Read from file created by you or by auto-create below
# LILA_PAYER_SECRET_FILE=

# 3) Auto-create key on first MCP start → ~/.openclaw/lila-payer.secret (fund USDC on testnet)
LILA_AUTO_CREATE_PAYER_WALLET=false

# Must match the API deployment
STELLAR_NETWORK=stellar:testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Dev only: allow server /api/agent/query without your payer key (not for production)
# LILA_ALLOW_SERVER_AGENT_QUERY=false
