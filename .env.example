# =============================================================================
# LILA: copy to .env and fill in. Never commit .env.
#
# Two roles — do not mix secrets:
#   • This file is mainly the HTTP API server (Railway, VPS, local `npm run dev:server`).
#   • External agents (OpenClaw MCP) need payer vars too — see config/mcp-client.env.example
#     (those run only in `node mcp/lila-server.mjs`, never on the API process).
# =============================================================================

# --- Stellar & x402 (required for real paid traffic) ---
# Docs: https://developers.stellar.org/docs/build/agentic-payments/x402
STELLAR_PAY_TO=
STELLAR_AGENT_SECRET=
STELLAR_NETWORK=stellar:testnet
FACILITATOR_URL=https://www.x402.org/facilitator
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Optional: offer native XLM (Soroban SAC / SEP-41) alongside USDC on x402 routes (second option in `accepts`; browser client still defaults to USDC).
# LILA_X402_ENABLE_XLM=true
# Notional USD price of 1 XLM used only to convert dollar list prices into XLM stroops — not an on-chain oracle.
# LILA_XLM_USD_RATE=0.17

# --- Optional: MPP Charge (Soroban SAC, parallel to x402) ---
# https://developers.stellar.org/docs/build/agentic-payments/mpp
# Same STELLAR_PAY_TO receives USDC. Clients use @stellar/mpp/charge/client (not @x402/fetch).
# MPP_ENABLED=false
# MPP_SECRET_KEY=  # random string for MPP challenge HMAC (not a Stellar secret key)

# --- HTTP server (production: https://lilagent.xyz) ---
PORT=3001
# NODE_ENV=production
# HTTPS behind reverse proxy: allow browser + agents from your public origin:
CORS_ORIGIN=https://lilagent.xyz
# ENABLE_HSTS=true
# RATE_LIMIT_MAX_PER_MIN=120

# --- Public site / CORS (API server) ---
# Public HTTPS origin of this deployment (no trailing slash).
LILA_PUBLIC_URL=https://lilagent.xyz

# Server-side only: agent/query → premium URL (Docker / reverse proxy). Usually localhost + PORT.
# LILA_INTERNAL_BASE_URL=http://127.0.0.1:3001

# --- External agent (MCP) — NOT read by Express ---
# Payer wallet, LILA_BASE_URL for MCP, auto-create, etc.: use config/mcp-client.env.example
# and set them in OpenClaw mcp.servers.*.env (or a dedicated env file for `npm run mcp` only).
# If MCP starts outside the repo, optional absolute path for dotenv in the MCP process:
# LILA_DOTENV_PATH=

# --- LLM inference ---
# groq | openclaw | openai | auto. auto = OpenClaw URL → Groq → OpenAI. Use groq on live if OpenClaw is configured but you want Groq.
LLM_PROVIDER=auto
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_GATEWAY_SCOPES=operator.read,operator.write
# OPENCLAW_CONNECT_WITH_DEVICE=true
# OPENCLAW_DEVICE_AUTH_FALLBACK=true
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=

# --- Vite / frontend (build-time) ---
# Same origin as https://lilagent.xyz → leave VITE_API_ORIGIN unset (browser uses /api on the same host).
# If API is on another host only: VITE_API_ORIGIN=https://api.lilagent.xyz
# VITE_API_ORIGIN=
# Public site URL (canonical / marketing); override if you use another domain.
VITE_SITE_URL=https://lilagent.xyz
VITE_GITHUB_URL=https://github.com/nrlartt/lila-agent
# Leave empty to use in-app /docs. Set only to override with an external docs URL.
# VITE_DOCS_URL=
VITE_X_URL=https://x.com/nrlartt
# VITE_UNICORNSTUDIO_PROJECT_ID=
