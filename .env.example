# =============================================================================
# LILA — copy to .env and fill in. Never commit .env.
# =============================================================================

# --- Stellar & x402 (required for real paid traffic) ---
# Docs: https://developers.stellar.org/docs/build/agentic-payments/x402
STELLAR_PAY_TO=
STELLAR_AGENT_SECRET=
STELLAR_NETWORK=stellar:testnet
FACILITATOR_URL=https://www.x402.org/facilitator
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# --- HTTP server ---
PORT=3001
# NODE_ENV=development
# CORS_ORIGIN=
# ENABLE_HSTS=true
# RATE_LIMIT_MAX_PER_MIN=120

# --- Remote OpenClaw / MCP agents (see docs/openclaw-mcp.md + config/openclaw-lila.mcp.example.json) ---
# Public base URL of this LILA API when deployed (HTTPS). Remote agents set MCP env LILA_BASE_URL to this value.
LILA_PUBLIC_URL=
# LILA_BASE_URL=  # MCP client → LILA HTTP (default http://127.0.0.1:$PORT if unset)
# LILA_INTERNAL_BASE_URL=  # LILA server → own /api/premium (Docker / reverse proxy)
# LILA_DOTENV_PATH=  # Absolute path to .env if MCP starts with cwd outside the repo

# --- LLM inference (priority: OpenClaw gateway > Groq > OpenAI > static) ---
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_GATEWAY_SCOPES=operator.read,operator.write
# OPENCLAW_CONNECT_WITH_DEVICE=true
# OPENCLAW_DEVICE_AUTH_FALLBACK=true
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=

# --- Vite / frontend (build-time) ---
# Express API origin when SPA is on GitHub Pages (e.g. https://api.example.com — no trailing slash)
# VITE_API_ORIGIN=
# VITE_GITHUB_URL=
# VITE_DOCS_URL=
# VITE_X_URL=
# VITE_UNICORNSTUDIO_PROJECT_ID=
